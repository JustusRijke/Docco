# One or more markdown or HTML files to convert (relative to this file)
file = "examples/Feature_Showcase.md"
# or: file = ["examples/Feature_Showcase.md", "examples/Other.md"]

# Output directory for generated PDFs (relative to this file)
# output = "."

# Output each file to its own subdirectory: {output}/{filename}/
# createdir = false

# Keep intermediate .md and .html files for debugging
# keep-intermediate = false

# Allow execution of Python code in inline directives (security risk)
# allow-python = false

# Output filename pattern for multilingual PDFs
# filename-template = "{filename}_{langcode}"

# Maximum image DPI for PDF output; images exceeding this are flagged with a warning
# dpi = 300

# Write log output to a file
# log-file = "docco.log"

# Shared library PO files applied as fallback translations (document PO takes precedence)
# library-po = ["shared/copyright.po", "shared/address.po"]

# Skip overwriting PDF if visually identical to existing output
# skip-identical = false

# DiffPDF visual comparison threshold (0.0-1.0, lower = stricter)
# diffpdf-threshold = 0.1

# DiffPDF rendering DPI for comparison
# diffpdf-dpi = 96

# Skip text content comparison in diffpdf (visual-only; useful when font subsets
# or metadata cause text extraction differences without visible changes)
# diffpdf-skip-text = false
